\n  };\n\n  useEffect(() => {\n    getDonars();\n  }, []);\n\n  return (\n    <Layout>\n      <div className=\"container mt-4\">\n        <table className=\"table\">\n          <thead>\n            <tr>\n              <th scope=\"col\">Blood Group</th>\n              <th scope=\"col\">Inventory TYpe</th>\n              <th scope=\"col\">Quantity</th>\n              <th scope=\"col\">Email</th>\n              <th scope=\"col\">Date</th>\n            </tr>\n          </thead>\n          <tbody>\n            {data?.map((record) => (\n              <tr key={record._id}>\n                <td>{record.bloodGroup}</td>\n                <td>{record.inventoryType}</td>\n                <td>{record.quantity}</td>\n                <td>{record.email}</td>\n                <td>{moment(record.createdAt).format(\"DD/MM/YYYY hh:mm A\")}</td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    </Layout>\n  );\n};\n\nexport default Donation;\n","C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Dashboard\\Analytics.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Dashboard\\OrganisationPage.js",["157"],[],"import React, { useEffect, useState } from \"react\";\nimport Layout from \"./../../components/shared/Layout/Layout\";\nimport moment from \"moment\";\nimport { useSelector } from \"react-redux\";\nimport API from \"../../services/API\";\n\nconst OrganisationPage = () => {\n  // get current user\n  const { user } = useSelector((state) => state.auth);\n  const [data, setData] = useState([]);\n  //find org records\n  const getOrg = async () => {\n    try {\n      if (user?.role === \"donar\") {\n        const { data } = await API.get(\"/inventory/get-orgnaisation\");\n        //   console.log(data);\n        if (data?.success) {\n          setData(data?.organisations);\n        }\n      }\n      if (user?.role === \"hospital\") {\n        const { data } = await API.get(\n          \"/inventory/get-orgnaisation-for-hospital\"\n        );\n        //   console.log(data);\n        if (data?.success) {\n          setData(data?.organisations);\n        }\n      }\n    } catch (error) {\n      console.log(error);\n    }\n  };\n\n  useEffect(() => {\n    getOrg();\n  }, [user]);\n\n  return (\n    <Layout>\n      <table className=\"table \">\n        <thead>\n          <tr>\n            <th scope=\"col\">Name</th>\n            <th scope=\"col\">Email</th>\n            <th scope=\"col\">Phone</th>\n            <th scope=\"col\">Address</th>\n            <th scope=\"col\">Date</th>\n          </tr>\n        </thead>\n        <tbody>\n          {data?.map((record) => (\n            <tr key={record._id}>\n              <td>{record.organisationName}</td>\n              <td>{record.email}</td>\n              <td>{record.phone}</td>\n              <td>{record.address}</td>\n              <td>{moment(record.createdAt).format(\"DD/MM/YYYY hh:mm A\")}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </Layout>\n  );\n};\n\nexport default OrganisationPage;\n","C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\auth\\Login.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Dashboard\\Donar.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Dashboard\\Consumer.js",["158"],[],"import React, { useEffect, useState } from \"react\";\nimport Layout from \"../../components/shared/Layout/Layout\";\nimport moment from \"moment\";\nimport API from \"../../services/API\";\nimport { useSelector } from \"react-redux\";\n\nconst Consumer = () => {\n  const { user } = useSelector((state) => state.auth);\n  const [data, setData] = useState([]);\n  //find donar records\n  const getDonars = async () => {\n    try {\n      const { data } = await API.post(\"/inventory/get-inventory-hospital\", {\n        filters: {\n          inventoryType: \"out\",\n          hospital: user?._id,\n        },\n      });\n      if (data?.success) {\n        setData(data?.inventory);\n        console.log(data);\n      }\n    } catch (error) {\n      console.log(error);\n    }\n  };\n\n  useEffect(() => {\n    getDonars();\n  }, []);\n\n  return (\n    <Layout>\n      <div className=\"container mt-4\">\n        <table className=\"table\">\n          <thead>\n            <tr>\n              <th scope=\"col\">Blood Group</th>\n              <th scope=\"col\">Inventory TYpe</th>\n              <th scope=\"col\">Quantity</th>\n              <th scope=\"col\">Email</th>\n              <th scope=\"col\">Date</th>\n            </tr>\n          </thead>\n          <tbody>\n            {data?.map((record) => (\n              <tr key={record._id}>\n                <td>{record.bloodGroup}</td>\n                <td>{record.inventoryType}</td>\n                <td>{record.quantity}</td>\n                <td>{record.email}</td>\n                <td>{moment(record.createdAt).format(\"DD/MM/YYYY hh:mm A\")}</td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    </Layout>\n  );\n};\n\nexport default Consumer;\n","C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Dashboard\\Hospitals.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\auth\\Register.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Admin\\DonarList.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Admin\\AdminHome.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Admin\\HospitalList.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\pages\\Admin\\OrgList.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\Routes\\ProtectedRoute.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\Routes\\PublicRoute.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\redux\\features\\auth\\authSlice.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\services\\API.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Spinner.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\modal\\Modal.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Layout\\Layout.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Layout\\Header.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\redux\\features\\auth\\authActions.js",["159"],[],"import { createAsyncThunk } from \"@reduxjs/toolkit\";\nimport API from \"../../../services/API\";\nimport { toast } from \"react-toastify\";\n\nexport const userLogin = createAsyncThunk(\n  \"auth/login\",\n  async ({ role, email, password }, { rejectWithValue }) => {\n    try {\n      const { data } = await API.post(\"/auth/login\", { role, email, password });\n      //store token\n      if (data.success) {\n        alert(data.message);\n        localStorage.setItem(\"token\", data.token);\n        window.location.replace(\"/\");\n      }\n      return data;\n    } catch (error) {\n      if (error.response && error.response.data.message) {\n        return rejectWithValue(error.response.data.message);\n      } else {\n        return rejectWithValue(error.message);\n      }\n    }\n  }\n);\n\n//register\nexport const userRegister = createAsyncThunk(\n  \"auth/register\",\n  async (\n    {\n      name,\n      role,\n      email,\n      password,\n      phone,\n      organisationName,\n      address,\n      hospitalName,\n      website,\n    },\n    { rejectWithValue }\n  ) => {\n    try {\n      const { data } = await API.post(\"/auth/register\", {\n        name,\n        role,\n        email,\n        password,\n        phone,\n        organisationName,\n        address,\n        hospitalName,\n        website,\n      });\n      if (data?.success) {\n        alert(\"User Registerd Successfully\");\n        window.location.replace(\"/login\");\n        // toast.success(\"User Registerd Successfully\");\n      }\n    } catch (error) {\n      console.log(error);\n      if (error.response && error.response.data.message) {\n        return rejectWithValue(error.response.data.message);\n      } else {\n        return rejectWithValue(error.message);\n      }\n    }\n  }\n);\n\n//current user\nexport const getCurrentUser = createAsyncThunk(\n  \"auth/getCurrentUser\",\n  async ({ rejectWithValue }) => {\n    try {\n      const res = await API.get(\"/auth/current-user\");\n      if (res.data) {\n        return res?.data;\n      }\n    } catch (error) {\n      console.log(error);\n      if (error.response && error.response.data.message) {\n        return rejectWithValue(error.response.data.message);\n      } else {\n        return rejectWithValue(error.message);\n      }\n    }\n  }\n);\n","C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Form\\Form.js",[],["160"],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Form\\InputType.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\components\\shared\\Layout\\Sidebar.js",[],[],"C:\\Users\\Dell\\OneDrive\\Desktop\\Blood-Bank-Mern-Stack-Project-main\\client\\src\\services\\authService.js",[],[],{"ruleId":"161","severity